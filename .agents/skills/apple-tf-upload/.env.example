# Copy to <repo>/.tf-upload.env and fill real values. Do not commit the real file.

# ios or macos
PLATFORM=macos

# Xcode archive target
SCHEME=InputLocker
TEAM_ID=ABCD123456

# Optional if auto-detection finds the wrong Xcode container.
# PROJECT_NAME=InputLocker.xcodeproj
# WORKSPACE_NAME=InputLocker.xcworkspace

# Validation. Prefer tests; set SKIP_XCODE_TESTS=1 only with a reason.
TEST_DESTINATION=platform=macOS
# TEST_TARGET=InputLockerTests
SKIP_XCODE_TESTS=0

# Useful for SwiftPM-based macOS repos before the Xcode archive step.
SWIFTPM_PRECHECK=1
SWIFTPM_BUILD_SCRIPT=Scripts/build-app.sh

# Preferred auth: App Store Connect API key.
# ASC_KEY_ID=ABCD123456
# ASC_ISSUER_ID=11111111-2222-3333-4444-555555555555
# ASC_KEY_PATH=/absolute/path/AuthKey_ABCD123456.p8

# Alternative auth: Apple ID app-specific password.
# ASC_USERNAME=you@example.com
# ASC_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# ASC_PROVIDER_PUBLIC_ID=

# Optional signing/export overrides.
# BUNDLE_ID=com.example.InputLocker
CODE_SIGN_STYLE=Automatic
# PROVISIONING_PROFILE_SPECIFIER=
# SIGNING_CERTIFICATE=
EXPORT_METHOD=app-store-connect
INTERNAL_ONLY=0
